# Copy this file to terraform.tfvars and customize for your environment
# Variables can also be set via environment variables (see README.md)

proxmox_nodes = ["pve1", "pve2", "pve3"]

default_storage = "local-lvm"
default_bridge  = "vmbr0"

nixos_template = "nixos-template"

# SSH public keys (newline separated)
# You can also use file("~/.ssh/id_rsa.pub")
ssh_public_keys = <<-EOT
ssh-ed25519 AAAAC3Nza... user@host
EOT

# Define NixOS VMs
nixos_vms = {
  "nixos-vm-01" = {
    target_node = "pve1"
    description = "NixOS development VM"
    cores       = 4
    memory      = 4096
    balloon     = 2048
    disks = [{
      type    = "scsi"
      storage = "local-lvm"
      size    = "64G"
      ssd     = 1
      discard = "on"
    }]
    # Static IP example:
    # ipconfig0 = "ip=10.0.0.100/24,gw=10.0.0.1"
    # DHCP:
    ipconfig0 = "ip=dhcp"
  }

  "nixos-vm-02" = {
    target_node = "pve2"
    description = "NixOS web server"
    cores       = 2
    memory      = 2048
    ipconfig0   = "ip=10.0.0.101/24,gw=10.0.0.1"
  }
}

# Define LXC containers
lxc_containers = {
  "docker-host" = {
    target_node = "pve1"
    ostemplate  = "local:vztmpl/ubuntu-22.04-standard_22.04-1_amd64.tar.zst"
    description = "Docker host container"
    cores       = 2
    memory      = 2048
    swap        = 1024
    rootfs_size = "16G"
    features_nesting = true  # Required for Docker
    networks = [{
      name   = "eth0"
      bridge = "vmbr0"
      ip     = "10.0.0.50/24"
      gw     = "10.0.0.1"
    }]
  }

  "monitoring" = {
    target_node = "pve2"
    ostemplate  = "local:vztmpl/debian-12-standard_12.2-1_amd64.tar.zst"
    description = "Monitoring container"
    cores       = 1
    memory      = 1024
    networks = [{
      name   = "eth0"
      bridge = "vmbr0"
      ip     = "dhcp"
    }]
  }
}
