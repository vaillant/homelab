# NixOS builder VM configuration
# Copy to terraform.tfvars and adjust for your setup
#
# Note: Variables are provided via Taskfile:
#   target_node, storage, nixos_version, ssh_pubkey

# VM resources
cores     = 4
memory    = 8192
disk_size = 64

# Storage
storage      = "local"       # For ISO/image files
disk_storage = "local-zfs"   # For VM disks

# Network
bridge     = "vmbr0"
ip_address = "dhcp"          # Or use CIDR notation: "10.0.0.100/24"
gateway    = ""              # Required if using static IP
