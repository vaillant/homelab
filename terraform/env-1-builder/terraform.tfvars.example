# NixOS builder environment configuration
# Copy to terraform.tfvars and adjust for your setup
#
# Note: target_node and ostemplate are provided via Makefile variables:
#   NODE, STORAGE, NIXOS_VERSION

cores       = 4
memory      = 8192
swap        = 4096
rootfs_size = "64G"

networks = [{
  name   = "eth0"
  bridge = "vmbr0"
  ip     = "dhcp"
}]

ssh_public_keys = <<-EOT
ssh-ed25519 AAAAC3Nza... user@host
EOT
